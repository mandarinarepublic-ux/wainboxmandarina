# ============================================================
# Variables de entorno — copia este archivo como .env.local
# y rellena tus valores reales
# ============================================================

# Webhook de Make para LEER mensajes del Google Sheet
# Escenario Make: Google Sheets Watch Rows → Webhook Response JSON
VITE_MAKE_READ_WEBHOOK=https://hook.eu2.make.com/TU_WEBHOOK_LEER

# Webhook de Make para ENVIAR respuestas por WhatsApp
# Escenario Make: Custom Webhook → HTTP Meta API → Sheets Add Row
VITE_MAKE_SEND_WEBHOOK=https://hook.eu2.make.com/TU_WEBHOOK_ENVIAR

# ============================================================
# En Vercel:
# Settings → Environment Variables → agrega las mismas claves
# ============================================================
